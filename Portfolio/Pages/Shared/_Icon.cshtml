@model string
@*
    Hand-drawn SVG icons. Pass the icon kind as the model string:
    "gmcodex", "timer", "homelab", "ssh", "post", "mail"
    Usage: @await Html.PartialAsync("_Icon", "timer")
*@
@{
    var kind = Model ?? "post";
    // Size defaults via CSS (tile-icon / row-icon sets parent size; SVG fills)
    var size = ViewData["size"] as int? ?? 64;
}

<svg width="@size" height="@size" viewBox="0 0 64 64" style="display:block" aria-hidden="true">
    @switch (kind)
    {
        case "gmcodex":
            <g stroke="currentColor" stroke-width="1.6" fill="none" stroke-linejoin="round" stroke-linecap="round">
                <path d="M 32 6 C 40 8, 52 14, 56 22 C 58 30, 54 42, 46 50 C 38 58, 26 58, 18 50 C 10 42, 6 30, 8 22 C 12 14, 24 8, 32 6 Z" />
                <path d="M 32 6 L 20 22 L 12 30 M 32 6 L 44 22 L 52 30 M 20 22 L 44 22 M 20 22 L 26 44 M 44 22 L 38 44 M 26 44 L 38 44 M 26 44 L 18 50 M 38 44 L 46 50 M 26 44 L 32 56 M 38 44 L 32 56" />
                <text x="32" y="34" font-family="'JetBrains Mono', monospace" font-size="10" font-weight="700" fill="currentColor" stroke="none" text-anchor="middle">20</text>
            </g>
            break;
        case "timer":
            <g stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 32 12 C 44 12, 54 22, 54 34 C 54 46, 44 56, 32 56 C 20 56, 10 46, 10 34 C 10 22, 20 12, 32 12 Z" />
                <path d="M 26 8 L 38 8" />
                <path d="M 32 16 L 32 20 M 50 34 L 46 34 M 32 52 L 32 48 M 14 34 L 18 34" />
                <path d="M 32 34 L 32 22 M 32 34 L 42 40" />
                <circle cx="32" cy="34" r="2" fill="currentColor" />
            </g>
            break;
        case "homelab":
            <g stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 10 14 L 54 14 L 54 24 L 10 24 Z" />
                <path d="M 10 28 L 54 28 L 54 38 L 10 38 Z" />
                <path d="M 10 42 L 54 42 L 54 52 L 10 52 Z" />
                <circle cx="16" cy="19" r="1.2" fill="currentColor" />
                <circle cx="20" cy="19" r="1.2" fill="currentColor" />
                <path d="M 44 19 L 50 19" />
                <circle cx="16" cy="33" r="1.2" fill="currentColor" />
                <circle cx="20" cy="33" r="1.2" fill="currentColor" />
                <path d="M 44 33 L 50 33" />
                <circle cx="16" cy="47" r="1.2" fill="currentColor" />
                <circle cx="20" cy="47" r="1.2" fill="currentColor" />
                <path d="M 44 47 L 50 47" />
            </g>
            break;
        case "ssh":
            <g stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 6 14 L 58 14 L 58 52 L 6 52 Z" />
                <path d="M 6 22 L 58 22" />
                <circle cx="12" cy="18" r="1.5" fill="currentColor" />
                <circle cx="18" cy="18" r="1.5" fill="currentColor" />
                <circle cx="24" cy="18" r="1.5" fill="currentColor" />
                <text x="12" y="38" font-family="'JetBrains Mono', monospace" font-size="9" font-weight="700" fill="currentColor" stroke="none">$ ssh</text>
                <path d="M 38 36 L 44 36" />
                <rect x="46" y="32" width="4" height="8" fill="currentColor" stroke="none">
                    <animate attributeName="opacity" values="1;0;1" dur="1s" repeatCount="indefinite" />
                </rect>
            </g>
            break;
        case "post":
            <g stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 14 8 L 44 8 L 52 16 L 52 56 L 14 56 Z" />
                <path d="M 44 8 L 44 16 L 52 16" />
                <path d="M 20 26 L 44 26 M 20 34 L 44 34 M 20 42 L 36 42" />
            </g>
            break;
        case "mail":
            <g stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path d="M 8 16 L 56 16 L 56 48 L 8 48 Z" />
                <path d="M 8 16 L 32 36 L 56 16" />
            </g>
            break;
    }
</svg>
